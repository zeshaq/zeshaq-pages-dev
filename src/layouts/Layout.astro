---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "zahid", description = "personal blog and whiteboard sessions" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="app-shell">
      <Sidebar currentPath={currentPath} />
      <main class="app-main">
        <div class="app-content">
          <slot />
        </div>
        <footer class="app-footer">
          <span>built with astro on cloudflare pages</span>
        </footer>
      </main>
    </div>

    <script is:inline>
      // Generic fullscreen toggler — any element with [data-fullscreen-target="<id>"]
      // will toggle fullscreen on the element with that id when clicked.
      document.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-fullscreen-target]");
        if (!btn) return;
        const target = document.getElementById(btn.dataset.fullscreenTarget);
        if (!target) return;
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          target.requestFullscreen?.();
        }
      });
    </script>
  </body>
</html>
