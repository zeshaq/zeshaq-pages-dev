---
import BracPocLayout from "../../layouts/BracPocLayout.astro";
import { getCollection, render } from "astro:content";
import { stripIdPrefixes } from "../../utils/navTree";

export async function getStaticPaths() {
  const items = await getCollection("brac-poc", ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: stripIdPrefixes(item.id) },
    props: { doc: item },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<BracPocLayout
  title={`${doc.data.title} — Brac POC`}
  description={doc.data.description}
  lastReviewed={doc.data.last_reviewed}
>
  <article class="doc-article prose" data-pagefind-body>
    <h1>{doc.data.title}</h1>
    {doc.data.description && (
      <p class="doc-description text-[var(--color-muted)]">{doc.data.description}</p>
    )}
    <Content />
  </article>
</BracPocLayout>
