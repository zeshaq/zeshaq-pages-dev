---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getCollection, render } from "astro:content";
import { stripIdPrefixes } from "../../utils/navTree";
import { moduleTitle } from "../../utils/docModules";

export async function getStaticPaths() {
  const docs = await getCollection("docs", ({ data }) => !data.draft);
  return docs.map((doc) => ({
    params: { slug: stripIdPrefixes(doc.id) },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

// The first id segment is the module folder (e.g. `openshift-platform`,
// `brac-poc`). Use the module's display title in the page title so search
// results and browser tabs are disambiguated when the same page name
// exists in multiple modules.
const [moduleId] = doc.id.split("/");
const modTitle = moduleTitle(moduleId);
---

<DocsLayout
  title={`${doc.data.title} — ${modTitle}`}
  description={doc.data.description}
  lastReviewed={doc.data.last_reviewed}
>
  <article class="doc-article prose" data-pagefind-body>
    <h1>{doc.data.title}</h1>
    {doc.data.description && (
      <p class="doc-description text-[var(--color-muted)]">{doc.data.description}</p>
    )}
    <Content />
  </article>
</DocsLayout>
