---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Layout title="Zahid's Blog">
  <section class="mb-12">
    <h1 class="text-2xl font-semibold mb-2">hi, i'm zahid</h1>
    <p class="text-[var(--color-muted)]">
      Notes and diagrams. Open the <a href="/whiteboard" target="_blank" rel="noopener" class="underline">whiteboard ↗</a> for an interactive board.
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-lg font-semibold mb-4 text-[var(--color-ink)]">sections</h2>
    <div class="section-cards">
      <a href="/docs/" class="section-card">
        <h3 class="section-card-title">Docs</h3>
        <p class="section-card-desc">Platform documentation, BRAC POC, ADRs, runbooks.</p>
      </a>
      <a href="/learn/" class="section-card">
        <h3 class="section-card-title">Learning</h3>
        <p class="section-card-desc">Self-paced tracks — Agentic AI, Cloudflare, ACM Multicluster.</p>
      </a>
      <a href="/whiteboard" class="section-card">
        <h3 class="section-card-title">Whiteboard</h3>
        <p class="section-card-desc">Interactive ReactFlow editor for sketching architectures.</p>
      </a>
    </div>
  </section>

  <section id="blog">
    <h2 class="text-lg font-semibold mb-4 text-[var(--color-ink)]">blog</h2>
    <ul class="space-y-2">
      {posts.map((post) => (
        <li class="flex items-baseline gap-3">
          <span class="text-xs text-[var(--color-muted)] font-mono w-24 shrink-0">{fmt(post.data.date)}</span>
          <a href={`/blog/${post.id}`} class="text-[var(--color-ink)] hover:underline">{post.data.title}</a>
        </li>
      ))}
      {posts.length === 0 && <li class="text-[var(--color-muted)] text-sm">no posts yet</li>}
    </ul>
  </section>
</Layout>
