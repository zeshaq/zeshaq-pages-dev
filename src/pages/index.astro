---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Layout title="zahid">
  <section class="mb-12">
    <h1 class="text-2xl font-semibold mb-2">hi, i'm zahid</h1>
    <p class="text-[var(--color-muted)]">
      Notes and diagrams. Read the <a href="/docs" class="underline">full-platform docs</a> for the OpenShift rebuild project, or open the <a href="/whiteboard" target="_blank" rel="noopener" class="underline">whiteboard ↗</a> for an interactive board.
    </p>
  </section>

  <section id="blog">
    <h2 class="text-lg font-semibold mb-4 text-[var(--color-ink)]">blog</h2>
    <ul class="space-y-2">
      {posts.map((post) => (
        <li class="flex items-baseline gap-3">
          <span class="text-xs text-[var(--color-muted)] font-mono w-24 shrink-0">{fmt(post.data.date)}</span>
          <a href={`/blog/${post.id}`} class="text-[var(--color-ink)] hover:underline">{post.data.title}</a>
        </li>
      ))}
      {posts.length === 0 && <li class="text-[var(--color-muted)] text-sm">no posts yet</li>}
    </ul>
  </section>
</Layout>
