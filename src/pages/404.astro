---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 — Page not found"
  description="The page you were looking for doesn't exist on Zahid's Blog."
>
  <section class="mb-12">
    <h1 class="text-2xl font-semibold mb-2">404 — page not found</h1>
    <p class="text-[var(--color-muted)] mb-6">
      The URL you tried doesn't map to anything on this site. It may have moved, been renamed, or never existed.
    </p>
    <p class="text-[var(--color-muted)]">
      Try the <a href="/" class="underline">blog home</a>, the <a href="/docs" class="underline">platform docs</a>, the <a href="/learn" class="underline">learning tracks</a>, or the <a href="/whiteboard" target="_blank" rel="noopener" class="underline">whiteboard ↗</a>.
    </p>
  </section>
</Layout>
