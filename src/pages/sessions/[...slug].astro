---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import Whiteboard from "../../components/Whiteboard";

export async function getStaticPaths() {
  const sessions = await getCollection("sessions");
  return sessions.map((session) => ({ params: { slug: session.id }, props: { session } }));
}

const { session } = Astro.props;
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Layout title={`${session.data.title} — zahid`} description={session.data.description}>
  <p class="text-xs text-[var(--color-muted)] font-mono mb-1">{fmt(session.data.date)}</p>
  <h1 class="text-2xl font-semibold mb-2 text-[var(--color-ink)]">{session.data.title}</h1>
  {session.data.description && (
    <p class="text-[var(--color-muted)] mb-6">{session.data.description}</p>
  )}
  <Whiteboard
    client:load
    data={{ nodes: session.data.nodes, edges: session.data.edges }}
    height="80vh"
  />
  <p class="text-xs text-[var(--color-muted)] mt-3">
    Pan with drag, zoom with scroll. Click ⛶ to go fullscreen, or replace the JSON in <code>src/content/sessions/</code>.
  </p>
</Layout>
