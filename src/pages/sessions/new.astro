---
import Layout from "../../layouts/Layout.astro";
import WhiteboardEditor from "../../components/WhiteboardEditor";
---

<Layout title="new session — zahid" description="Create a new whiteboard session">
  <h1 class="text-2xl font-semibold mb-1 text-[var(--color-ink)]">new session</h1>
  <p class="text-sm text-[var(--color-muted)] mb-5">
    Build a board, then export the JSON into <code>src/content/sessions/</code> to publish.
  </p>
  <WhiteboardEditor client:only="react" />
</Layout>
