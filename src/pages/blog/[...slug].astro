---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toISOString().slice(0, 10);

const canonicalURL = new URL(`/blog/${post.id}`, Astro.site).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description ?? "",
  datePublished: post.data.date.toISOString(),
  author: { "@type": "Person", name: "Zahid" },
  publisher: {
    "@type": "Organization",
    name: "Zahid's Blog",
    url: "https://zeshaq.pages.dev",
  },
  url: canonicalURL,
  image: new URL("/og-default.svg", Astro.site).toString(),
  ...(post.data.category && { articleSection: post.data.category }),
};
---

<Layout
  title={`${post.data.title} — Zahid's Blog`}
  description={post.data.description}
  type="article"
  published={post.data.date}
  category={post.data.category}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <article class="prose max-w-none">
    <p class="text-xs text-[var(--color-muted)] font-mono mb-1">{fmt(post.data.date)}</p>
    <h1 class="text-2xl font-semibold mb-6 text-[var(--color-ink)]">{post.data.title}</h1>
    <Content />
  </article>
</Layout>
