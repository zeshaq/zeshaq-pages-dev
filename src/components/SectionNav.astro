---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Normalize trailing slash for comparison.
const p = currentPath.replace(/\/+$/, "") || "/";

const isHome = p === "" || p === "/" || p.startsWith("/blog");
const isLearn = p.startsWith("/learn");
const isDocs = p.startsWith("/docs");
const isWhiteboard = p === "/whiteboard";
---

<nav class="section-nav" aria-label="Site sections">
  <a
    href="/"
    class:list={["section-icon", { "section-icon-active": isHome }]}
    title="Home — Blog"
    aria-label="Home — Blog"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
      <polyline points="9 22 9 12 15 12 15 22" />
    </svg>
  </a>

  <a
    href="/learn/"
    class:list={["section-icon", { "section-icon-active": isLearn }]}
    title="Learn"
    aria-label="Learn"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 10v6" />
      <path d="m2 10 10-5 10 5-10 5z" />
      <path d="M6 12v5c3 3 9 3 12 0v-5" />
    </svg>
  </a>

  <a
    href="/docs/"
    class:list={["section-icon", { "section-icon-active": isDocs }]}
    title="Docs"
    aria-label="Docs"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
    </svg>
  </a>

  <a
    href="/whiteboard"
    target="_blank"
    rel="noopener"
    class:list={["section-icon", { "section-icon-active": isWhiteboard }]}
    title="Whiteboard (opens in a new tab)"
    aria-label="Whiteboard"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
    </svg>
  </a>
</nav>
