---
import { getCollection } from "astro:content";
import NavNode from "./NavNode.astro";
import SectionNav from "./SectionNav.astro";
import Search from "./Search.astro";
import { buildDocsTree, buildModuleTree, type NavNode as NavNodeT } from "../utils/navTree";
import { parseDocsPath, moduleTitle, MODULE_TITLES } from "../utils/docModules";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const docs = await getCollection("docs", ({ data }) => !data.draft);

// Decide which sub-tree to render. Inside a module (`/docs/<module>/...`)
// the sidebar scopes to that module so the reader isn't drowned in
// cross-module pages; on the master `/docs/` landing it shows all modules
// grouped (the existing buildDocsTree gives us that for free, with module
// folders as the first-level groups).
const ctx = parseDocsPath(currentPath);
const inModule = (ctx.isModuleHome || ctx.isModulePage) && !!ctx.moduleId && ctx.moduleId in MODULE_TITLES;
const moduleId = inModule ? ctx.moduleId! : undefined;

const tree: NavNodeT[] = moduleId
  ? buildModuleTree(docs, moduleId, "/docs")
  : buildDocsTree(docs, "/docs");

const brand = moduleId ? moduleTitle(moduleId) : "Documentation";
const brandHref = moduleId ? `/docs/${moduleId}/` : "/docs";
---

<aside class="sidebar">
  <details class="sidebar-toggle" open>
    <summary class="sidebar-summary">
      <div class="sidebar-brand-row">
        <a href="/" class="sidebar-home-btn" title="Home — Blog" aria-label="Home" onclick="event.stopPropagation()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </a>
        <a href={brandHref} class="sidebar-brand" onclick="event.stopPropagation()">{brand}</a>
      </div>
      <span class="sidebar-hamburger" aria-hidden="true">≡</span>
    </summary>

    <SectionNav currentPath={currentPath} />

    <Search />

    {moduleId && (
      <div class="sidebar-contextual">
        <a href="/docs/" class="sidebar-context-link">
          ← back to all documentation
        </a>
      </div>
    )}

    <div class="sidebar-filter-wrap">
      <input
        type="search"
        class="sidebar-filter"
        placeholder="filter docs…"
        autocomplete="off"
        spellcheck="false"
        data-filter
      />
    </div>

    <nav class="sidebar-nav">
      <ul data-filter-list>
        {tree.length === 0 ? (
          <li class="docs-empty">No pages yet — check back soon.</li>
        ) : (
          tree.map((node) => (
            <li>
              <NavNode node={node} currentPath={currentPath} />
            </li>
          ))
        )}
      </ul>
    </nav>
  </details>
</aside>

<script is:inline>
  (() => {
    const input = document.querySelector("[data-filter]");
    const root = document.querySelector("[data-filter-list]");
    if (!input || !root) return;

    const filter = (li, q) => {
      const link = li.querySelector(":scope > a.nav-link");
      if (link) {
        const match = !q || link.textContent.toLowerCase().includes(q);
        li.style.display = match ? "" : "none";
        return match;
      }
      const details = li.querySelector(":scope > details");
      if (details) {
        const summary = details.querySelector(":scope > summary");
        const summaryMatch = !q || (summary?.textContent.toLowerCase().includes(q) ?? false);
        const childUl = details.querySelector(":scope > ul");
        let anyChild = false;
        if (childUl) {
          for (const child of childUl.children) {
            if (child.tagName === "LI" && filter(child, q)) anyChild = true;
          }
        }
        const visible = summaryMatch || anyChild;
        li.style.display = visible ? "" : "none";
        if (q && anyChild) details.open = true;
        return visible;
      }
      return true;
    };

    const apply = () => {
      const q = input.value.trim().toLowerCase();
      for (const li of root.children) {
        if (li.tagName === "LI") filter(li, q);
      }
    };

    input.addEventListener("input", apply);
  })();
</script>
