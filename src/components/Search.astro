---
// Site-wide search powered by Pagefind. Pagefind generates its index and UI
// assets at build time into /pagefind/*; this component renders a trigger
// button that opens a <dialog> hosting the Pagefind default UI, and wires up
// the Cmd/Ctrl+K keyboard shortcut.
//
// In `astro dev` the /pagefind/* assets don't exist (they're build artifacts),
// so the script gracefully degrades — the button still appears but clicking
// shows a placeholder message.
---

<button class="search-trigger" id="site-search-trigger" type="button" aria-label="Search (⌘K)">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8" />
    <path d="m21 21-4.3-4.3" />
  </svg>
  <span class="search-trigger-label">Search…</span>
  <kbd class="search-kbd">⌘K</kbd>
</button>

<dialog id="site-search-modal" class="search-modal" aria-label="Site search">
  <div class="search-modal-inner">
    <button type="button" class="search-close" aria-label="Close search">×</button>
    <div id="site-search-ui"></div>
    <p class="search-footer">Press <kbd>Esc</kbd> to close · <kbd>↑↓</kbd> to navigate</p>
  </div>
</dialog>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  (() => {
    const trigger = document.getElementById("site-search-trigger");
    const modal = document.getElementById("site-search-modal");
    const closeBtn = modal?.querySelector(".search-close");
    let initialized = false;

    function initUI() {
      if (initialized || typeof window.PagefindUI === "undefined") return;
      try {
        new window.PagefindUI({
          element: "#site-search-ui",
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          autofocus: true,
          translations: { placeholder: "Search blog, docs, learn…" },
        });
        initialized = true;
      } catch (e) {
        console.warn("Pagefind UI init failed", e);
      }
    }

    function openModal() {
      if (!modal) return;
      if (typeof window.PagefindUI === "undefined") {
        alert("Search is built at deploy time — try `npm run build && npm run preview` locally, or use the live site.");
        return;
      }
      initUI();
      modal.showModal();
      // Focus the Pagefind input.
      setTimeout(() => {
        const input = modal.querySelector(".pagefind-ui__search-input");
        if (input instanceof HTMLInputElement) input.focus();
      }, 30);
    }

    function closeModal() {
      modal?.close();
    }

    trigger?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
      // Click on the backdrop (the dialog itself, not its content) closes.
      if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", (e) => {
      const cmdOrCtrl = e.metaKey || e.ctrlKey;
      if (cmdOrCtrl && e.key.toLowerCase() === "k") {
        e.preventDefault();
        openModal();
      }
      // Native <dialog> already closes on Esc; this is just belt + braces.
      if (e.key === "Escape" && modal?.open) {
        e.preventDefault();
        closeModal();
      }
    });
  })();
</script>
